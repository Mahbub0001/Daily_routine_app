<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Diagonal planetary ring showing Orbit / Routine symmetry -->
    <path
        android:pathData="M 30,76 C 14,56 26,32 50,22 C 74,12 94,30 78,62 C 62,94 46,96 30,76 Z"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:strokeColor="#02E6C4">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="30"
                android:startY="76"
                android:endX="78"
                android:endY="62"
                android:type="linear">
                <item android:offset="0.0" android:color="#00000000" />
                <item android:offset="1.0" android:color="#00000000" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Star centerpiece with glowing gradient -->
    <path
        android:pathData="M54,34 A20,20 0 1,1 54,74 A20,20 0 1,1 54,34 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="54"
                android:startY="34"
                android:endX="54"
                android:endY="74"
                android:type="linear">
                <item android:offset="0.0" android:color="#8B63FF" />
                <item android:offset="1.0" android:color="#02E6C4" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Inner central white sun focal point -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,44 A10,10 0 1,1 54,64 A10,10 0 1,1 54,44 Z" />

    <!-- Twin tiny companion stars (Cosmic sparkles representing streaks!) -->
    <!-- Sparkle East-North -->
    <path
        android:fillColor="#FFFFC633"
        android:pathData="M 76,32 L 78,30 L 80,32 L 78,34 Z" />
    
    <!-- Sparkle West-South -->
    <path
        android:fillColor="#FFFFC633"
        android:pathData="M 28,74 L 30,72 L 32,74 L 30,76 Z" />
</vector>
